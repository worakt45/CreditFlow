    <script>
        let dashboardChartInstance = null;
        let gaugeChartInstance = null;
        let benchmarkChartInstance = null;

        const state = {
            currentSector: '',
            calculatedScore: 72
        };

        function navTo(viewId) {
            ['dashboard', 'assessment', 'approvals'].forEach(id => {
                document.getElementById('view-' + id).classList.add('hidden');
                document.getElementById('nav-' + id).classList.remove('bg-white/10', 'text-gold');
                document.getElementById('nav-' + id).classList.add('hover:bg-white/5');
            });
            
            document.getElementById('view-' + viewId).classList.remove('hidden');
            document.getElementById('nav-' + viewId).classList.add('bg-white/10', 'text-gold');
            document.getElementById('nav-' + viewId).classList.remove('hover:bg-white/5');

            if(viewId === 'dashboard' && !dashboardChartInstance) {
                renderDashboardChart();
            }
        }

        function processStep(stepNum, data = null) {
            if (stepNum === 1) {
                const input = document.getElementById('companyInput').value;
                if(!input) { alert('กรุณาระบุชื่อบริษัท'); return; }
                document.getElementById('step-2').classList.add('step-active');
            } 
            else if (stepNum === 2) {
                state.currentSector = data;
                document.getElementById('step-3').classList.add('step-active');
            }
            else if (stepNum === 3) {
                const de = parseFloat(document.getElementById('inputDE').value);
                const ar = parseInt(document.getElementById('inputAR').value);
                
                state.calculatedScore = 100 - (de * 5) - ((ar - 60) * 0.5);
                state.calculatedScore = Math.max(0, Math.min(100, Math.round(state.calculatedScore)));

                document.getElementById('step-4').classList.add('step-active');
                renderAssessmentCharts(ar, de);
                
                const warningBox = document.getElementById('warningBox');
                if(ar > 75) {
                    warningBox.style.display = 'block';
                } else {
                    warningBox.style.display = 'none';
                }
            }
        }

        function resetAssessment() {
            document.getElementById('companyInput').value = '';
            document.getElementById('step-2').classList.remove('step-active');
            document.getElementById('step-3').classList.remove('step-active');
            document.getElementById('step-4').classList.remove('step-active');
            if(gaugeChartInstance) gaugeChartInstance.destroy();
            if(benchmarkChartInstance) benchmarkChartInstance.destroy();
        }

        function renderDashboardChart() {
            const ctx = document.getElementById('dashboardChart').getContext('2d');
            dashboardChartInstance = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: ['ต.ค.', 'พ.ย.', 'ธ.ค.', 'ม.ค.', 'ก.พ.', 'มี.ค.'],
                    datasets: [{
                        label: 'ยอดอนุมัติ (ล้านบาท)',
                        data: [25, 32, 28, 40, 38, 45.2],
                        backgroundColor: '#C5A059',
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: { beginAtZero: true, grid: { color: '#f0f0f0' } },
                        x: { grid: { display: false } }
                    }
                }
            });
        }

        function renderAssessmentCharts(arDays, deRatio) {
            if(gaugeChartInstance) gaugeChartInstance.destroy();
            if(benchmarkChartInstance) benchmarkChartInstance.destroy();

            const score = state.calculatedScore;
            let gaugeColor = '#88929C'; 
            if(score > 80) gaugeColor = '#C5A059'; 
            else if (score < 50) gaugeColor = '#ef4444'; 

            document.getElementById('riskLevelText').innerText = score > 80 ? 'LOW RISK' : (score < 50 ? 'HIGH RISK' : 'MEDIUM RISK');
            document.getElementById('riskLevelText').style.color = gaugeColor;

            const ctxGauge = document.getElementById('scoreGaugeChart').getContext('2d');
            gaugeChartInstance = new Chart(ctxGauge, {
                type: 'doughnut',
                data: {
                    labels: ['Score', 'Remaining'],
                    datasets: [{
                        data: [score, 100 - score],
                        backgroundColor: [gaugeColor, '#e2e8f0'],
                        borderWidth: 0,
                        cutout: '80%'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    rotation: -90,
                    circumference: 180,
                    plugins: {
                        legend: { display: false },
                        tooltip: { enabled: false }
                    }
                },
                plugins: [{
                    id: 'textCenter',
                    beforeDraw: function(chart) {
                        var width = chart.width, height = chart.height, ctx = chart.ctx;
                        ctx.restore();
                        var fontSize = (height / 80).toFixed(2);
                        ctx.font = "bold " + fontSize + "em Prompt";
                        ctx.textBaseline = "bottom";
                        ctx.fillStyle = "#1E293B";
                        var text = score + "",
                            textX = Math.round((width - ctx.measureText(text).width) / 2),
                            textY = height - 10;
                        ctx.fillText(text, textX, textY);
                        ctx.save();
                    }
                }]
            });

            const ctxBench = document.getElementById('benchmarkChart').getContext('2d');
            benchmarkChartInstance = new Chart(ctxBench, {
                type: 'bar',
                data: {
                    labels: ['AR Days (วัน)', 'D/E Ratio (เท่า)'],
                    datasets: [
                        {
                            label: 'บริษัทลูกค้า',
                            data: [arDays, deRatio * 20], 
                            backgroundColor: '#3B4335',
                            borderRadius: 4
                        },
                        {
                            label: 'ค่าเฉลี่ยอุตสาหกรรม',
                            data: [75, 1.5 * 20], 
                            backgroundColor: '#d1d5db',
                            borderRadius: 4
                        }
                    ]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    let val = context.raw;
                                    if(context.dataIndex === 1) val = val / 20; 
                                    return context.dataset.label + ': ' + val;
                                }
                            }
                        }
                    },
                    scales: {
                        x: { display: false },
                        y: { grid: { display: false } }
                    }
                }
            });
        }

        navTo('dashboard');
    </script>
</body>
</html>
